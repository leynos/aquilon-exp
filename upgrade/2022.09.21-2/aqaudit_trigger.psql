CREATE OR REPLACE FUNCTION _xtn_id_delete() RETURNS TRIGGER AS
$$BEGIN
	DELETE FROM xtn_detail WHERE xtn_id = OLD.id;
	DELETE FROM xtn_end WHERE xtn_id = OLD.id;
	RETURN OLD;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER _xtn_id_delete
BEFORE DELETE ON xtn
FOR EACH ROW
EXECUTE PROCEDURE _xtn_id_delete();
