    <refnamediv>
        <refname>aq update machine</refname>
        <refpurpose>
            Update a machine by hardware name or hostname.
        </refpurpose>
        <refclass>Aquilon</refclass>
    </refnamediv>

    <refsynopsisdiv>
        <cmdsynopsis>
            <command>aq update machine</command>
            <group>
                <synopfragmentref linkend="global-options">Global options</synopfragmentref>
            </group>
            <group choice="req">
                <group choice="req">
                    <arg choice="plain"><option>--hostname <replaceable>FQDN</replaceable></option></arg>
                    <arg choice="plain"><option>--machine <replaceable>LABEL</replaceable></option></arg>
                </group>
                <group>
                    <arg choice="plain"><option>--chassis <replaceable>FQDN</replaceable></option></arg>
                    <arg choice="plain"><option>--slot <replaceable>NUMBER</replaceable></option></arg>
                </group>
                <group>
                    <arg><option>--rack <replaceable>NAME</replaceable></option></arg>
                    <arg><option>--desk <replaceable>NAME</replaceable></option></arg>
                    <arg><option>--cluster <replaceable>NAME</replaceable></option></arg>
                    <arg><option>--metacluster <replaceable>NAME</replaceable></option></arg>
                    <arg><option>--vmhost <replaceable>FQFDN</replaceable></option></arg>
                </group>
                <arg><option>--model <replaceable>NAME</replaceable></option></arg>
                <arg><option>--recipe <replaceable>JSON</replaceable></option></arg>
                <arg><option>--vendor <replaceable>NAME</replaceable></option></arg>
                <arg><option>--cpuname <replaceable>NAME</replaceable></option></arg>
                <arg><option>--cpuvendor <replaceable>NAME</replaceable></option></arg>
                <arg><option>--cpucount <replaceable>NUMBER</replaceable></option></arg>
                <arg><option>--memory <replaceable>NUMBER</replaceable></option></arg>
                <arg><option>--serial <replaceable>SERIAL</replaceable></option></arg>
                <arg><option>--uuid <replaceable>UUID</replaceable></option></arg>
                <arg><option>--clear_uuid</option></arg>
                <group>
                    <arg choice="plain"><option>--clearchassis</option></arg>
                    <arg choice="plain"><option>--noclearchassis</option></arg>
                </group>
                <group>
                    <arg choice="plain"><option>--multislot</option></arg>
                    <arg choice="plain"><option>--nomultislot</option></arg>
                </group>
                <group>
                    <arg choice="plain"><option>--allow_metacluster_change</option></arg>
                    <arg choice="plain"><option>--noallow_metacluster_change</option></arg>
                </group>
                <arg><option>--uri <replaceable>URI</replaceable></option></arg>
                <arg><option>--remap_disk <replaceable>REMAP_DISK</replaceable></option></arg>
