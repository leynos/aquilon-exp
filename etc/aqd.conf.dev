# The config file etc/aqd.conf.defaults always gets read first, and the
# values below override those.  To nullify a value from the defaults,
# it must be explicitly set to an empty value here.
#
# This should work "out of the box" for development purposes.
# To connect to an Postgres database, copy this file and adjust the
# [database_postgres] parameters as appropriate.  Then, change
# database_section to point to database_postgres.

[DEFAULT]
basedir = /var/tmp/%(user)s
quattordir = %(basedir)s/quattor

[database]
database_section = database_sqlite
#log_query_times = yes
#log_query_plans = yes
#log_unique_plans_only = yes

[broker]
run_git_daemon = True
#server_notifications = cdb2sql bootserver
client_notifications = no

[panc]
version = beta

[tool_locations]
dsdb = /bin/echo
mean = %(srcdir)s/tests/fakebin/fake_mean

[dsdb]
dsdb_use_testdb = True
enable = True
network_enable = True

[ib-services]
enable = True
enabled_features = address, address_alias, alias, chassis, console_server, dynamic_range, host, interface, interface_address, machine, manager, network_device, router_address, service_address, srv_record
transactional = True
urls = https://ib-services.l0.ms.com
cache_location = %(quattordir)s/aquilondb/ib_services_cache.db

[change_management]
# The contents of --justification will not be validated externally
# (syntax checking will still be performed)
enable = True
extra_options = --mode enforce --disable_edm --edm-instance qa
obo_service_ids =

[site]
ipfromtype = True

[netseg]
enable = True
